{
  "name": "prescribe-co-backend",
  "version": "1.0.0",
  "description": "Prescribe & Co — NestJS backend",
  "scripts": {
    "build": "nest build",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
