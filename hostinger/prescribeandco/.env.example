APP_NAME="Prescribe & Co"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u123456789_prescribe
DB_USERNAME=u123456789_appuser
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=false

CACHE_STORE=file

# JWT — generate two random strings: php -r "echo bin2hex(random_bytes(32));"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Rate limiting (requests per minute)
THROTTLE_DEFAULT=20
THROTTLE_AUTH=5
THROTTLE_REFRESH=10

CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# AWS S3 (for prescription document storage — leave blank to skip)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=
S3_PRESIGNED_TTL=900

# Stripe (add live keys before going live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RETURN_URL=https://yourdomain.com/payment/return
